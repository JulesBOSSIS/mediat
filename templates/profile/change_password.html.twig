{% extends 'base.html.twig' %}

{% block title %}Changer le mot de passe - MediaT{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .profile-avatar {
            width: 4.25rem;
            height: 4.25rem;
            background: linear-gradient(135deg, var(--bs-primary) 0%, #5a67d8 100%);
            box-shadow: 0 0.35rem 1rem rgba(var(--bs-primary-rgb), 0.35);
        }
        .profile-sidebar .nav-link {
            color: var(--bs-body-color);
            font-weight: 500;
            font-size: 0.9rem;
        }
        .profile-sidebar .nav-link:hover { background: rgba(var(--bs-primary-rgb), 0.08); }
        .profile-sidebar .nav-link.active {
            background: rgba(var(--bs-primary-rgb), 0.15);
            color: var(--bs-primary);
        }
    </style>
{% endblock %}

{% block body %}
<div class="container-fluid px-3 px-lg-4 py-4">
    <div class="row g-4">
        <div class="col-lg-3 col-xl-3">
            {% include 'profile/_nav_sidebar.html.twig' with { current_route: 'app_profile_change_password' } %}
        </div>

        <div class="col-lg-9 col-xl-9">
            <!-- Contenu Profil -->
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h4 class="mb-4">
                        <i class="bi bi-lock me-2"></i>
                        Changer votre mot de passe
                    </h4>
                    <hr>

                    {% for message in app.flashes('success') %}
                        <div class="alert alert-success alert-dismissible fade show d-flex align-items-center" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            <div>
                                {{ message }}
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    {% endfor %}

                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <div>
                                {{ message }}
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    {% endfor %}

                    <form method="post" class="mt-4">
                        <div class="mb-4">
                            <label for="{{ form.currentPassword.vars.id }}" class="form-label fw-semibold">
                                <i class="bi bi-lock me-1"></i>
                                {{ form.currentPassword.vars.label }}
                            </label>
                            {{ form_widget(form.currentPassword, {
                                'attr': {
                                    'class': 'form-control' ~ (form.currentPassword.vars.errors|length > 0 ? ' is-invalid' : '')
                                }
                            }) }}
                            {% if form.currentPassword.vars.errors|length > 0 %}
                                <div class="invalid-feedback d-block">
                                    {% for error in form.currentPassword.vars.errors %}
                                        {{ error.message }}
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>

                        <hr>

                        <div class="mb-4">
                            <p>Veuillez entrer votre nouveau mot de passe (minimum 14 caractères) :</p>
                            <label for="{{ form.plainPassword.first.vars.id }}" class="form-label fw-semibold">
                                <i class="bi bi-shield-lock me-1"></i>
                                {{ form.plainPassword.first.vars.label }}
                            </label>
                            {{ form_widget(form.plainPassword.first, {
                                'attr': {
                                    'class': 'form-control' ~ (form.plainPassword.first.vars.errors|length > 0 ? ' is-invalid' : '')
                                }
                            }) }}
                            {% if form.plainPassword.first.vars.errors|length > 0 %}
                                <div class="invalid-feedback d-block">
                                    {% for error in form.plainPassword.first.vars.errors %}
                                        {{ error.message }}
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>

                        <div class="mb-4">
                            <label for="{{ form.plainPassword.second.vars.id }}" class="form-label fw-semibold">
                                <i class="bi bi-shield-lock me-1"></i>
                                {{ form.plainPassword.second.vars.label }}
                            </label>
                            {{ form_widget(form.plainPassword.second, {
                                'attr': {
                                    'class': 'form-control' ~ (form.plainPassword.second.vars.errors|length > 0 ? ' is-invalid' : '')
                                }
                            }) }}
                            {% if form.plainPassword.second.vars.errors|length > 0 %}
                                <div class="invalid-feedback d-block">
                                    {% for error in form.plainPassword.second.vars.errors %}
                                        {{ error.message }}
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>

                        <hr>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg me-2"></i>
                                Mettre à jour le mot de passe
                            </button>
                            <a href="{{ path('app_profile') }}" class="btn btn-secondary">
                                <i class="bi bi-x-lg me-2"></i>
                                Annuler
                            </a>
                        </div>

                        {{ form_rest(form) }}
                    </form>

                    <div class="alert alert-info mt-4" role="alert">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>Conseil de sécurité :</strong> Utilisez un mot de passe fort comprenant des majuscules, des minuscules, des chiffres et des caractères spéciaux.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
