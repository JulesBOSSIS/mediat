{% extends 'base.html.twig' %}

{% block title %}Accueil - MediaT{% endblock %}

{% block body %}
<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item active" aria-current="page">
                <i class="bi bi-house-door me-1"></i>
                Accueil
            </li>
        </ol>
    </nav>
    
    <!-- Header de bienvenue -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="hero-section text-white rounded-3 p-5 d-flex align-items-center justify-content-center text-center" data-tour="tour-accueil-hero">
                <div class="hero-content">
                    <h1 class="display-4 fw-bold mb-4">
                        <i class="bi bi-collection me-3"></i>
                        MediaT
                    </h1>
                    <p class="lead mb-0 lh-lg">
                        Votre plateforme centralisée de documentation. Accédez facilement à toutes les ressources dont vous avez besoin pour maîtriser vos outils et contenus.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Section Avantages de la centralisation -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5">
                    <h2 class="h3 mb-4">
                        <i class="bi bi-diagram-3 me-2" style="color: #0d6efd;"></i>
                        Pourquoi centraliser vos ressources ?
                    </h2>
                    <p class="lead text-muted mb-4">
                        La recherche, la maintenance et le partage de fichiers peuvent nécessiter beaucoup de temps. Une centralisation permet :
                    </p>
                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <div class="d-flex">
                                <div class="flex-shrink-0">
                                    <div class="d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background-color: #e7f1ff; border-radius: 50%;">
                                        <i class="bi bi-box2 text-primary" style="font-size: 1.3rem;"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <h5 class="mb-2">Centraliser les ressources</h5>
                                    <p class="text-muted mb-0">Évitez la perte documentaire en consolidant tous vos contenus au même endroit</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="d-flex">
                                <div class="flex-shrink-0">
                                    <div class="d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background-color: #e8f5e9; border-radius: 50%;">
                                        <i class="bi bi-share text-success" style="font-size: 1.3rem;"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <h5 class="mb-2">Améliorer la diffusion</h5>
                                    <p class="text-muted mb-0">Facilitez le partage et la diffusion des ressources dans toute l'organisation</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="d-flex">
                                <div class="flex-shrink-0">
                                    <div class="d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background-color: #fff3e0; border-radius: 50%;">
                                        <i class="bi bi-shield-lock text-warning" style="font-size: 1.3rem;"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <h5 class="mb-2">Assurer la sécurité</h5>
                                    <p class="text-muted mb-0">Garantissez le contrôle et la sécurité des données diffusées avec gestion des droits d'accès</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="d-flex">
                                <div class="flex-shrink-0">
                                    <div class="d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background-color: #fce4ec; border-radius: 50%;">
                                        <i class="bi bi-exclamation-triangle text-danger" style="font-size: 1.3rem;"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <h5 class="mb-2">Limiter les risques</h5>
                                    <p class="text-muted mb-0">Réduisez les canaux de diffusion non sécurisés en centralisant l'accès</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Section Objectifs de MediaT -->
    <div class="row mb-5">
        <div class="col-lg-6 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <h3 class="card-title mb-4">
                        <i class="bi bi-lightning-charge me-2" style="color: #ffc107;"></i>
                        Gagnez en efficacité
                    </h3>
                    <ul class="list-unstyled">
                        <li class="mb-3">
                            <div class="d-flex">
                                <i class="bi bi-check-circle-fill text-success me-2 mt-1"></i>
                                <span><strong>Centraliser</strong> tous les médias et gagner du temps pour les équipes</span>
                            </div>
                        </li>
                        <li class="mb-3">
                            <div class="d-flex">
                                <i class="bi bi-check-circle-fill text-success me-2 mt-1"></i>
                                <span><strong>Diffuser collectivement</strong> le même niveau d'information</span>
                            </div>
                        </li>
                        <li class="mb-3">
                            <div class="d-flex">
                                <i class="bi bi-check-circle-fill text-success me-2 mt-1"></i>
                                <span><strong>Accès sans multiplication</strong> de canaux de diffusion</span>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-lg-6 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <h3 class="card-title mb-4">
                        <i class="bi bi-shield-check me-2" style="color: #28a745;"></i>
                        Maîtrisez vos outils
                    </h3>
                    <ul class="list-unstyled">
                        <li class="mb-3">
                            <div class="d-flex">
                                <i class="bi bi-check-circle-fill text-success me-2 mt-1"></i>
                                <span><strong>CTIMUT</strong> - Renforcez votre maîtrise du logiciel de gestion</span>
                            </div>
                        </li>
                        <li class="mb-3">
                            <div class="d-flex">
                                <i class="bi bi-check-circle-fill text-success me-2 mt-1"></i>
                                <span><strong>CRM</strong> - Guides et procédures complets</span>
                            </div>
                        </li>
                        <li class="mb-3">
                            <div class="d-flex">
                                <i class="bi bi-check-circle-fill text-success me-2 mt-1"></i>
                                <span><strong>Espace Entreprise & Espace PS</strong> - Ressources didactiques valorisées</span>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Section Données Réglementaires -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="card border-0 shadow-sm bg-light">
                <div class="card-body p-5">
                    <div class="row align-items-center">
                        <div class="col-lg-2 text-center mb-4 mb-lg-0">
                            <i class="bi bi-file-earmark-text text-primary" style="font-size: 4rem;"></i>
                        </div>
                        <div class="col-lg-10">
                            <h3 class="mb-3">
                                <i class="bi bi-bookmark-check me-2"></i>
                                Données réglementaires
                            </h3>
                            <p class="lead mb-2">
                                Accédez facilement à toutes les ressources réglementaires incontournables pour votre activité mutualiste.
                            </p>
                            <p class="text-muted">
                                Centralisez et consultez les liens vers les différents sites institutionnels essentiels, tout en ayant un accès sécurisé et organisé à l'ensemble de la documentation réglementaire.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Section Gestion des contenus -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5">
                    <h2 class="h3 mb-5">
                        <i class="bi bi-sliders me-2" style="color: #0d6efd;"></i>
                        Gestion et régulation des contenus
                    </h2>
                    <div class="row">
                        <div class="col-md-4 mb-4 text-center">
                            <div class="mb-3">
                                <div class="d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 50%; margin: 0 auto;">
                                    <i class="bi bi-search text-white" style="font-size: 2.5rem;"></i>
                                </div>
                            </div>
                            <h5 class="mb-3">Indexation précise</h5>
                            <p class="text-muted">Trouvez exactement ce que vous cherchez grâce à une organisation et une indexation rigoureuses</p>
                        </div>
                        <div class="col-md-4 mb-4 text-center">
                            <div class="mb-3">
                                <div class="d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); border-radius: 50%; margin: 0 auto;">
                                    <i class="bi bi-lock text-white" style="font-size: 2.5rem;"></i>
                                </div>
                            </div>
                            <h5 class="mb-3">Gestion des droits</h5>
                            <p class="text-muted">Accès contrôlé aux ressources selon les rôles et permissions de chacun</p>
                        </div>
                        <div class="col-md-4 mb-4 text-center">
                            <div class="mb-3">
                                <div class="d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); border-radius: 50%; margin: 0 auto;">
                                    <i class="bi bi-shield-exclamation text-white" style="font-size: 2.5rem;"></i>
                                </div>
                            </div>
                            <h5 class="mb-3">Sécurisation</h5>
                            <p class="text-muted">Protégez vos ressources critiques avec une infrastructure sécurisée</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Statistiques finales -->
    <div class="row mb-5">
        <div class="col-md-4 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <i class="bi bi-file-text text-primary" style="font-size: 2.5rem;"></i>
                    <h4 class="mt-3 mb-1">{{ totalDocuments }}</h4>
                    <p class="text-muted mb-0">Document{{ totalDocuments > 1 ? 's' : '' }}</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <i class="bi bi-folder text-success" style="font-size: 2.5rem;"></i>
                    <h4 class="mt-3 mb-1">{{ totalFolders }}</h4>
                    <p class="text-muted mb-0">Catégorie{{ totalFolders > 1 ? 's' : '' }}</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <i class="bi bi-bookmarks text-warning" style="font-size: 2.5rem;"></i>
                    <h4 class="mt-3 mb-1">{{ rootFolders|length }}</h4>
                    <p class="text-muted mb-0">Section{{ rootFolders|length > 1 ? 's' : '' }} accessible{{ rootFolders|length > 1 ? 's' : '' }}</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hero-section {
        background: linear-gradient(135deg, #185f8d 0%, #0d6efd 50%, #0056b3 100%);
        min-height: 400px;
        position: relative;
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
    }
    
    .hero-content {
        max-width: 800px;
        z-index: 1;
        background: rgba(255, 255, 255, 0.2);
        padding: 40px;
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
    }
    
    .card {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }
    
    .card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.15) !important;
    }
    
    .bg-gradient {
        background: linear-gradient(135deg, #007bff, #0056b3) !important;
    }
    
    .list-unstyled li {
        transition: transform 0.2s ease-in-out;
    }

    .list-unstyled li:hover {
        transform: translateX(5px);
    }
</style>
{% endblock %}
