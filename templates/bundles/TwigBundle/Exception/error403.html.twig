{% extends "base_error.html.twig" %}

{% block title %}Accès refusé - 403{% endblock %}

{% block body %}
<style>
    .error-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
        text-align: center;
        padding: 40px 20px;
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
        border-radius: 10px;
        margin: 40px 0;
    }
    .error-container h1 {
        font-size: 120px;
        font-weight: bold;
        margin: 0;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }
    .error-container .error-title {
        font-size: 32px;
        font-weight: 600;
        margin: 20px 0 10px 0;
    }
    .error-container .error-description {
        font-size: 16px;
        max-width: 500px;
        margin: 20px 0 30px 0;
        opacity: 0.9;
        line-height: 1.6;
    }
    .error-container .error-icon {
        font-size: 80px;
        margin-bottom: 20px;
    }
    .error-container .btn {
        display: inline-block;
        padding: 12px 30px;
        background-color: white;
        color: #f5576c;
        text-decoration: none;
        border-radius: 5px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: 2px solid white;
        margin-top: 10px;
    }
    .error-container .btn:hover {
        background-color: transparent;
        color: white;
    }
</style>

<div class="error-container">
    <div class="error-icon">🚫</div>
    <h1>403</h1>
    <p class="error-title">Accès refusé</p>
    <p class="error-description">
        Vous n'avez pas la permission d'accéder à cette ressource.<br>
        Contactez un administrateur si vous pensez que c'est une erreur.
    </p>
    <a href="{{ path('app_accueil') }}" class="btn">Retour à l'accueil</a>
</div>
{% endblock %}
