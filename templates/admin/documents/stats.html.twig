{% extends 'admin/admin_base.html.twig' %}
{% import 'admin/_macros.html.twig' as admin_ui %}

{% block title %}Statistiques des consultations — Admin{% endblock %}

{% block admin_toolbar %}
    {{ admin_ui.back_bar(path('app_admin'), "Panneau d'administration") }}
{% endblock %}

{% block admin_content %}
{% include 'admin/documents/_nav_documents_tabs.html.twig' with { tabs_context: 'stats' } %}

<div class="mb-4">
    <h1 class="admin-page-title mb-2">
        <i class="bi bi-bar-chart-line text-primary me-2"></i>
        Statistiques globales
    </h1>
    <p class="admin-page-lead text-muted mb-0">
        Agrégation des consultations PDF (une ouverture au plus toutes les 5&nbsp;minutes par utilisateur et par document).
        Les comptes <strong>ROLE_ADMIN</strong> sont exclus des lignes «&nbsp;utilisateur&nbsp;».
    </p>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card admin-card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-uppercase text-muted small fw-semibold mb-1" style="font-size: 0.65rem; letter-spacing: 0.06em;">Ouvertures</div>
                <div class="fs-4 fw-semibold">{{ summary.totalOpens }}</div>
                <div class="small text-muted mt-1">Même périmètre que les tableaux</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card admin-card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-uppercase text-muted small fw-semibold mb-1" style="font-size: 0.65rem; letter-spacing: 0.06em;">Lecteurs</div>
                <div class="fs-4 fw-semibold">{{ summary.distinctUsers }}</div>
                <div class="small text-muted mt-1">Utilisateurs distincts (hors admin)</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card admin-card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-uppercase text-muted small fw-semibold mb-1" style="font-size: 0.65rem; letter-spacing: 0.06em;">Documents touchés</div>
                <div class="fs-4 fw-semibold">{{ summary.distinctDocuments }}</div>
                <div class="small text-muted mt-1">Au moins une ouverture</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card admin-card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-uppercase text-muted small fw-semibold mb-1" style="font-size: 0.65rem; letter-spacing: 0.06em;">Moyenne / lecteur</div>
                <div class="fs-4 fw-semibold">
                    {% if summary.distinctUsers > 0 %}
                        {{ (summary.totalOpens / summary.distinctUsers)|number_format(1, ',', ' ') }}
                    {% else %}
                        —
                    {% endif %}
                </div>
                <div class="small text-muted mt-1">Ouvertures par utilisateur</div>
            </div>
        </div>
    </div>
</div>

<div class="card admin-card admin-filter-card border-0 shadow-sm mb-4">
    <div class="card-header py-3 rounded-top">
        <span class="fw-semibold"><i class="bi bi-funnel me-2"></i>Filtres</span>
    </div>
    <div class="card-body">
        <form method="get" action="{{ path('app_admin_documents_view_stats') }}">
            <div class="row g-3">
                <div class="col-md-3">
                    <label for="startDate" class="form-label">Date de début</label>
                    <input type="date" class="form-control" id="startDate" name="startDate" value="{{ startDate ?? '' }}">
                </div>
                <div class="col-md-2">
                    <label for="startTime" class="form-label">Heure</label>
                    <input type="time" class="form-control" id="startTime" name="startTime" value="{{ startTime ?? '00:00' }}">
                </div>
                <div class="col-md-3">
                    <label for="endDate" class="form-label">Date de fin</label>
                    <input type="date" class="form-control" id="endDate" name="endDate" value="{{ endDate ?? '' }}">
                </div>
                <div class="col-md-2">
                    <label for="endTime" class="form-label">Heure</label>
                    <input type="time" class="form-control" id="endTime" name="endTime" value="{{ endTime ?? '23:59' }}">
                </div>
                <div class="col-md-12 col-lg-8">
                    <label for="user" class="form-label">E-mail utilisateur (contient)</label>
                    <input type="search" class="form-control" id="user" name="user" value="{{ userQuery }}" placeholder="ex. @exemple.fr" autocomplete="off">
                </div>
                <div class="col-md-6 col-lg-2">
                    <label for="userSort" class="form-label">Tri utilisateurs</label>
                    <select class="form-select" id="userSort" name="userSort">
                        <option value="opens" {% if userSort == 'opens' %}selected{% endif %}>Ouvertures</option>
                        <option value="docs" {% if userSort == 'docs' %}selected{% endif %}>Documents consultés</option>
                        <option value="last" {% if userSort == 'last' %}selected{% endif %}>Dernière activité</option>
                    </select>
                </div>
                <div class="col-md-6 col-lg-2">
                    <label for="top" class="form-label">Top documents</label>
                    <input type="number" class="form-control" id="top" name="top" min="1" max="100" value="{{ topLimit }}" title="Nombre de lignes (1 à 100)">
                </div>
            </div>
            <div class="d-flex flex-wrap gap-2 mt-3">
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="bi bi-search me-1"></i>Appliquer
                </button>
                <a href="{{ path('app_admin_documents_view_stats') }}" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-x-lg me-1"></i>Réinitialiser
                </a>
            </div>
        </form>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <h2 class="h6 fw-semibold mb-3">
            <i class="bi bi-people me-2 text-primary"></i>Par utilisateur
        </h2>
        {% if byUser is empty %}
            <div class="alert alert-info border-0 shadow-sm mb-0">
                <i class="bi bi-info-circle me-2"></i>Aucune donnée pour ces critères.
            </div>
        {% else %}
            <div class="admin-table-wrap card admin-card border-0 shadow-sm">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">Utilisateur</th>
                                <th scope="col" class="text-end">Ouvertures</th>
                                <th scope="col" class="text-end">Fichiers</th>
                                <th scope="col">Première</th>
                                <th scope="col">Dernière</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in byUser %}
                                <tr>
                                    <td>
                                        <span class="text-break">{{ row.email }}</span>
                                        <span class="d-block small text-muted">ID {{ row.userId }}</span>
                                    </td>
                                    <td class="text-end">
                                        <span class="badge text-bg-primary rounded-pill">{{ row.viewCount }}</span>
                                    </td>
                                    <td class="text-end">
                                        <span class="badge text-bg-secondary rounded-pill">{{ row.distinctDocuments }}</span>
                                    </td>
                                    <td class="text-nowrap small">{{ row.firstViewedAt|date('d/m/Y H:i') }}</td>
                                    <td class="text-nowrap small">{{ row.lastViewedAt|date('d/m/Y H:i') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}
    </div>
    <div class="col-lg-6">
        <h2 class="h6 fw-semibold mb-3">
            <i class="bi bi-trophy me-2 text-warning"></i>Documents les plus consultés (top&nbsp;{{ topLimit }})
        </h2>
        {% if topDocuments is empty %}
            <div class="alert alert-info border-0 shadow-sm mb-0">
                <i class="bi bi-info-circle me-2"></i>Aucune donnée pour ces critères.
            </div>
        {% else %}
            <div class="admin-table-wrap card admin-card border-0 shadow-sm">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">Document</th>
                                <th scope="col">Dossier</th>
                                <th scope="col" class="text-end">Ouvertures</th>
                                <th scope="col" class="text-end">Lecteurs</th>
                                <th scope="col" class="text-end"></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for doc in topDocuments %}
                                <tr>
                                    <td>
                                        <span class="fw-medium text-break">{{ doc.title }}</span>
                                        <span class="d-block small text-muted">#{{ doc.documentId }}</span>
                                    </td>
                                    <td>
                                        <span class="badge text-bg-light border">{{ doc.folderName }}</span>
                                    </td>
                                    <td class="text-end">
                                        <span class="badge text-bg-primary rounded-pill">{{ doc.viewCount }}</span>
                                    </td>
                                    <td class="text-end">
                                        <span class="badge text-bg-secondary rounded-pill">{{ doc.distinctUsers }}</span>
                                    </td>
                                    <td class="text-end text-nowrap">
                                        <a href="{{ path('app_admin_document_views', { id: doc.documentId }) }}" class="btn btn-sm btn-outline-primary">
                                            Détail
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
