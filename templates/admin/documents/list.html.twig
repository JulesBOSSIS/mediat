{% extends 'admin/admin_base.html.twig' %}
{% import 'admin/_macros.html.twig' as admin_ui %}

{% block title %}Gestion des documents - Admin{% endblock %}

{% block admin_toolbar %}
    {{ admin_ui.back_bar(path('app_admin'), "Panneau d'administration") }}
{% endblock %}

{% block admin_content %}
<div class="d-flex flex-column flex-md-row align-items-md-start justify-content-md-between gap-3 mb-2">
    <div>
        <h1 class="admin-page-title mb-2">
            <i class="bi bi-files text-primary me-2"></i>
            Documents
        </h1>
        <p class="admin-page-lead text-muted mb-0">Liste, ordre d'affichage et indicateurs de consultation.</p>
    </div>
    <div class="flex-shrink-0">
        <a href="{{ path('app_admin_create_document') }}" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>
            Ajouter un document
        </a>
    </div>
</div>

{% include 'admin/documents/_nav_documents_tabs.html.twig' with { tabs_context: 'list' } %}

{% if documents is empty %}
    <div class="alert alert-info border-0 shadow-sm">
        Aucun document. <a href="{{ path('app_admin_create_document') }}">Ajouter un document</a>.
    </div>
{% else %}
    <div class="admin-table-wrap card admin-card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col" style="min-width: 220px;">Document</th>
                        <th scope="col" class="text-center">Format</th>
                        <th scope="col">Dossier</th>
                        <th scope="col" class="text-center">Pos.</th>
                        <th scope="col" style="min-width: 160px;">Consultations</th>
                        <th scope="col" style="min-width: 140px;">Emplacement</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for document in documents %}
                        {% set unique = documentViewRepository.countUniqueViews(document) %}
                        {% set total = documentViewRepository.countTotalViews(document) %}
                        <tr>
                            <td>
                                <span class="fw-semibold d-block text-break">{{ document.title }}</span>
                                <span class="small text-muted">#{{ document.id }}</span>
                            </td>
                            <td class="text-center">
                                {% if document.isLink() %}
                                    <span class="badge rounded-pill text-bg-info bg-opacity-25 text-info-emphasis border border-info-subtle">
                                        <i class="bi bi-link-45deg me-1"></i>Lien
                                    </span>
                                {% elseif document.isPdf() %}
                                    <span class="badge rounded-pill text-bg-danger bg-opacity-10 text-danger-emphasis border border-danger-subtle">
                                        <i class="bi bi-file-earmark-pdf me-1"></i>PDF
                                    </span>
                                {% elseif document.mimeType and document.mimeType starts with 'image/' %}
                                    <span class="badge rounded-pill text-bg-secondary border">
                                        <i class="bi bi-image me-1"></i>{{ document.shortFormatLabel }}
                                    </span>
                                {% else %}
                                    <span class="badge rounded-pill text-bg-light border text-secondary text-uppercase" style="font-size: 0.7rem;">
                                        <i class="bi bi-file-earmark me-1"></i>{{ document.shortFormatLabel }}
                                    </span>
                                {% endif %}
                            </td>
                            <td>
                                <span class="badge text-bg-light border fw-normal">{{ document.folder.name }}</span>
                            </td>
                            <td class="text-center">
                                <span class="text-muted">{{ document.position }}</span>
                            </td>
                            <td>
                                <div class="small">
                                    <span class="fw-semibold">{{ unique }}</span>
                                    <span class="text-muted">{{ unique == 1 ? 'lecteur' : 'lecteurs' }}</span>
                                    <span class="text-muted mx-1">·</span>
                                    <span class="fw-semibold">{{ total }}</span>
                                    <span class="text-muted">{{ total == 1 ? 'ouverture' : 'ouvertures' }}</span>
                                </div>
                                <a href="{{ path('app_admin_document_views', { id: document.id }) }}" class="btn btn-link btn-sm px-0 py-0 align-baseline">
                                    Détail et filtres<i class="bi bi-arrow-right-short"></i>
                                </a>
                            </td>
                            <td>
                                {% if document.isLink() %}
                                    <a href="{{ document.path }}" target="_blank" rel="noopener" class="small text-truncate d-inline-block" style="max-width: 200px;">
                                        {{ document.path }}
                                    </a>
                                {% else %}
                                    <code class="small text-secondary text-truncate d-inline-block" style="max-width: 200px;" title="{{ document.path }}">{{ document.path }}</code>
                                {% endif %}
                            </td>
                            <td class="text-end text-nowrap">
                                <a href="{{ path('app_admin_edit_document', {'id': document.id}) }}" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form action="{{ path('app_admin_delete_document', {'id': document.id}) }}" method="POST" class="d-inline" onsubmit="return confirm('Supprimer ce document ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ document.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endif %}
{% endblock %}
