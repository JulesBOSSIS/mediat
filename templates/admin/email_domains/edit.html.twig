{% extends 'admin/admin_base.html.twig' %}
{% import 'admin/_macros.html.twig' as admin_ui %}

{% block title %}Modifier un domaine email - Admin{% endblock %}

{% block admin_toolbar %}
    {{ admin_ui.back_bar(path('app_admin_email_domains_list'), 'Liste des domaines') }}
{% endblock %}

{% block admin_content %}
<h1 class="admin-page-title mb-2">
    <i class="bi bi-pencil text-primary me-2"></i>
    Modifier @{{ domain.domain }}
</h1>
<p class="admin-page-lead text-muted mb-4">Activez ou désactivez l'acceptation des inscriptions sur ce domaine.</p>

<div class="card admin-card border-0 shadow-sm">
    <div class="card-body p-4">
        {{ form_start(form) }}

        <div class="mb-3">
            {{ form_label(form.domain) }}
            {{ form_widget(form.domain, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.domain) }}
            {% if form.domain.vars.help %}
                <div class="form-text">{{ form.domain.vars.help }}</div>
            {% endif %}
        </div>

        <div class="mb-4">
            <div class="form-check">
                {{ form_widget(form.isActive, {'attr': {'class': 'form-check-input'}}) }}
                {{ form_label(form.isActive, null, {'label_attr': {'class': 'form-check-label'}}) }}
            </div>
            {{ form_errors(form.isActive) }}
            {% if form.isActive.vars.help %}
                <div class="form-text">{{ form.isActive.vars.help }}</div>
            {% endif %}
        </div>

        <div class="d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>Enregistrer
            </button>
            <a href="{{ path('app_admin_email_domains_list') }}" class="btn btn-outline-secondary">
                Annuler
            </a>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
