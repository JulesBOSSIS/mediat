{% extends 'admin/admin_base.html.twig' %}
{% import 'admin/_macros.html.twig' as admin_ui %}

{% block title %}Domaines email autorisés - Admin{% endblock %}

{% block admin_toolbar %}
    {{ admin_ui.back_bar(path('app_admin'), "Panneau d'administration") }}
{% endblock %}

{% block admin_content %}
<div class="d-flex flex-column flex-md-row align-items-md-start justify-content-md-between gap-3 mb-4">
    <div>
        <h1 class="admin-page-title mb-2">
            <i class="bi bi-envelope-check text-primary me-2"></i>
            Domaines email autorisés
        </h1>
        <p class="admin-page-lead text-muted mb-0">Contrôle des suffixes d'adresse acceptés à l'inscription.</p>
    </div>
    <div class="flex-shrink-0">
        <a href="{{ path('app_admin_email_domains_create') }}" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>
            Ajouter un domaine
        </a>
    </div>
</div>

{% if domains is empty %}
    <div class="alert alert-info border-0 shadow-sm">
        <i class="bi bi-info-circle me-2"></i>
        Aucun domaine configuré. <a href="{{ path('app_admin_email_domains_create') }}">Ajoutez-en un</a>.
    </div>
{% else %}
    <div class="admin-table-wrap card admin-card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Domaine</th>
                        <th scope="col">Statut</th>
                        <th scope="col">Création</th>
                        <th scope="col">Modification</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for domain in domains %}
                        <tr>
                            <td><strong>@{{ domain.domain }}</strong></td>
                            <td>
                                {% if domain.isActive %}
                                    <span class="badge rounded-pill text-bg-success bg-opacity-10 text-success-emphasis border border-success-subtle">Actif</span>
                                {% else %}
                                    <span class="badge rounded-pill text-bg-secondary bg-opacity-25 border">Inactif</span>
                                {% endif %}
                            </td>
                            <td class="small text-muted">{{ domain.createdAt|format_datetime('medium', 'short') }}</td>
                            <td class="small text-muted">{{ domain.updatedAt|format_datetime('medium', 'short') }}</td>
                            <td class="text-end text-nowrap">
                                <a href="{{ path('app_admin_email_domains_edit', {'id': domain.id}) }}" class="btn btn-sm btn-outline-primary" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="POST" action="{{ path('app_admin_email_domains_toggle', {'id': domain.id}) }}" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-secondary" title="{{ domain.isActive ? 'Désactiver' : 'Activer' }}" onclick="return confirm('{{ domain.isActive ? 'Désactiver' : 'Activer' }} ce domaine ?');">
                                        <i class="bi bi-{{ domain.isActive ? 'toggle-off' : 'toggle-on' }}"></i>
                                    </button>
                                </form>
                                <form method="POST" action="{{ path('app_admin_email_domains_delete', {'id': domain.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer ce domaine ?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endif %}
{% endblock %}
