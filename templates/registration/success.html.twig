{% extends 'base_public.html.twig' %}

{% block title %}Demande d'inscription validée - MediaT{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    body {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    
    .success-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 0;
    }
    
    .success-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        max-width: 500px;
        width: 100%;
        text-align: center;
    }
    
    .success-header {
        background: linear-gradient(135deg, #28a745, #20c997);
        color: white;
        padding: 3rem 1.5rem;
    }
    
    .success-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
    }
    
    .success-body {
        padding: 2rem 1.5rem;
    }
    
    .email-badge {
        background-color: #e9ecef;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        color: #2c3e50;
        margin: 1rem 0;
    }
    
    .info-box {
        background-color: #f8f9fa;
        padding: 1.5rem;
        border-left: 4px solid #28a745;
        border-radius: 8px;
        margin: 1.5rem 0;
        text-align: left;
    }
    
    .info-box h5 {
        color: #2c3e50;
        margin-bottom: 0.75rem;
    }
    
    .info-box ul {
        margin-bottom: 0;
        padding-left: 1.25rem;
    }
    
    .info-box li {
        margin-bottom: 0.5rem;
    }
    
    .btn-primary-custom {
        background: linear-gradient(135deg, #667eea, #764ba2);
        border: none;
        border-radius: 10px;
        padding: 12px 30px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: all 0.3s ease;
    }
    
    .btn-primary-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
    }
</style>
{% endblock %}

{% block body %}
<div class="success-container">
    <div class="success-card">
        <div class="success-header">
            <div class="success-icon">
                ✓
            </div>
            <h2>Demande reçue !</h2>
            <p class="mb-0 opacity-75">Votre inscription a été enregistrée</p>
        </div>
        
        <div class="success-body">
            <h4 class="mb-3">Prochaines étapes</h4>
            
            <div class="email-badge">
                {{ email }}
            </div>
            
            <div class="info-box">
                <h5><i class="bi bi-clock-history me-2"></i>En attente de validation</h5>
                <ul>
                    <li>Votre demande d'inscription a été enregistrée</li>
                    <li>Un administrateur l'examinera dans les plus brefs délais</li>
                    <li>Vous recevrez une confirmation par email une fois approuvée</li>
                </ul>
            </div>
            
            <div class="info-box">
                <h5><i class="bi bi-exclamation-triangle me-2"></i>Important</h5>
                <ul>
                    <li>Ne partagez jamais vos identifiants avec d'autres personnes</li>
                    <li>Conservez votre mot de passe en sécurité</li>
                    <li>Vérifiez régulièrement votre courrier électronique</li>
                </ul>
            </div>
            
            <a href="{{ path('app_login') }}" class="btn btn-primary-custom">
                <i class="bi bi-arrow-left me-2"></i>
                Retour à la page de connexion
            </a>
        </div>
    </div>
</div>

<!-- Footer info -->
<div class="position-fixed bottom-0 start-0 end-0 text-center text-white-50 p-3">
    <small>
        © {{ "now"|date("Y") }} MediaT</small>
</div>
{% endblock %}
