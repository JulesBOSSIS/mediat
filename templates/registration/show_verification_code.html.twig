{% extends 'base_public.html.twig' %}

{% block title %}Code de vérification - MediaT{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    body {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    
    .verify-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 0;
    }
    
    .verify-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        max-width: 600px;
        width: 100%;
    }
    
    .verify-header {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        text-align: center;
        padding: 2rem 1.5rem 1.5rem;
    }
    
    .verify-body {
        padding: 2rem 1.5rem;
    }
    
    .email-badge {
        background-color: #e9ecef;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        color: #2c3e50;
        margin: 1rem 0;
        text-align: center;
    }
    
    .code-display {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        padding: 2rem;
        border-radius: 15px;
        text-align: center;
        margin: 2rem 0;
        box-shadow: 0 5px 15px rgba(102, 126, 234, 0.3);
    }
    
    .code-display .code-label {
        font-size: 0.9rem;
        opacity: 0.9;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    
    .code-display .code-value {
        font-size: 3rem;
        font-weight: bold;
        letter-spacing: 8px;
        font-family: 'Courier New', monospace;
    }
    
    .warning-box {
        background-color: #fff3cd;
        border-left: 4px solid #ffc107;
        padding: 1.5rem;
        border-radius: 8px;
        margin: 1.5rem 0;
    }
    
    .warning-box h5 {
        color: #856404;
        margin-bottom: 0.75rem;
    }
    
    .warning-box p {
        color: #856404;
        margin-bottom: 0.5rem;
    }
    
    .info-box {
        background-color: #f8f9fa;
        padding: 1.5rem;
        border-left: 4px solid #667eea;
        border-radius: 8px;
        margin: 1.5rem 0;
    }
    
    .info-box h5 {
        color: #2c3e50;
        margin-bottom: 0.75rem;
    }
    
    .btn-primary {
        background: linear-gradient(135deg, #667eea, #764ba2);
        border: none;
        border-radius: 10px;
        padding: 12px 24px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: all 0.3s ease;
    }
    
    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
    }
    
    .token-info {
        background-color: #f8f9fa;
        padding: 1rem;
        border-radius: 8px;
        margin-top: 1rem;
        font-size: 0.85rem;
        color: #6c757d;
        word-break: break-all;
    }
</style>
{% endblock %}

{% block body %}
<div class="verify-container">
    <div class="verify-card">
        <div class="verify-header">
            <div style="font-size: 3rem; margin-bottom: 1rem;">🔐</div>
            <h2 class="mb-2">Code de vérification</h2>
            <p class="mb-0 opacity-75">MediaT</p>
        </div>
        
        <div class="verify-body">
            {% for message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-circle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
            
            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
            
            <div class="warning-box">
                <h5><i class="bi bi-exclamation-triangle me-2"></i>Solution temporaire</h5>
                <p class="mb-0">
                    L'envoi d'email est temporairement désactivé. Utilisez le code ci-dessous pour valider votre inscription.
                </p>
            </div>
            
            <p class="text-center mb-3">Code de vérification pour l'adresse email :</p>
            
            <div class="email-badge">
                <i class="bi bi-envelope me-2"></i>{{ email }}
            </div>
            
            <div class="code-display">
                <div class="code-label">Votre code de vérification</div>
                <div class="code-value">{{ verificationCode }}</div>
            </div>
            
            <div class="info-box">
                <h5><i class="bi bi-info-circle me-2"></i>Instructions</h5>
                <ul class="mb-0">
                    <li>Copiez le code ci-dessus</li>
                    <li>Cliquez sur le bouton ci-dessous pour accéder à la page de validation</li>
                    <li>Collez le code dans le formulaire de validation</li>
                    <li>Le code est valide pendant 30 minutes</li>
                </ul>
            </div>
            
            <div class="d-grid gap-2">
                <a href="{{ path('app_verify_code', {'id': registrationRequestId}) }}" class="btn btn-primary">
                    <i class="bi bi-arrow-right-circle me-2"></i>
                    Valider mon compte avec ce code
                </a>
            </div>
            
            <div class="text-center mt-4">
                <p class="text-muted mb-2">Vous avez besoin d'un nouveau code ?</p>
                <a href="{{ path('app_register') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>
                    Refaire une demande
                </a>
            </div>
            
            <div class="token-info">
                <small>
                    <i class="bi bi-shield-lock me-1"></i>
                    <strong>Token de sécurité :</strong> {{ token }}
                    <br>
                    <em>Ce token est unique et permet d'accéder à votre code de vérification de manière sécurisée.</em>
                </small>
            </div>
        </div>
    </div>
</div>

<!-- Footer info -->
<div class="position-fixed bottom-0 start-0 end-0 text-center text-white-50 p-3">
    <small>
        © {{ "now"|date("Y") }} MediaT</small>
</div>
{% endblock %}
